<?xml version="1.0"?>
<ruleset name="post-terms-block-unlinked">
	<description>Coding standards for post-terms-block-unlinked</description>

	<file>.</file>
	<arg name="basepath" value="./"/><!-- Strip the file paths down to the relevant bit -->

	<exclude-pattern>*/vendor/*</exclude-pattern>

	<!-- Rules: figuren.theater Coding Standards -->
	<rule ref="figurentheater" />

	<!-- Allow additional text_domains -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="post-terms-block-unlinked"/>
				<element value="default"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="ptbu"/>
				<element value="__NAMESPACE__"/>
			</property>

		</properties>
	</rule>
	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName" />
	</rule>
	<rule ref="Universal">
		<exclude name="Universal.Lists.DisallowShortListSyntax"/>
		<exclude name="Universal.Namespaces.EnforceCurlyBraceSyntax.Forbidden" />
		<exclude name="Universal.PHP.RequireExitDieParentheses.Missing" />
		<exclude name="Universal.Classes.RequireFinalClass.NonFinalClassFound" />
		<exclude name="Universal.Files.SeparateFunctionsFromOO.Mixed" />
	</rule>
</ruleset>
